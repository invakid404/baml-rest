{
  "name": "trailing_commas_nested_object_array",
  "description": "Trailing commas in a nested object, a nested array, and at the top level; BAML's JSONish parser tolerates them all. Native fixing parser claims it. want captured from BAML final parse.",
  "preserve_schema_order": true,
  "schema": {
    "classes": [
      {
        "name": "Root",
        "properties": [
          {"name": "inner", "type": {"kind": "class_ref", "ref": "Inner"}},
          {"name": "list", "type": {"kind": "list", "inner": {"kind": "int"}}}
        ]
      },
      {
        "name": "Inner",
        "properties": [
          {"name": "x", "type": {"kind": "int"}},
          {"name": "y", "type": {"kind": "int"}}
        ]
      }
    ],
    "root_class": "Root"
  },
  "raw": "{\"inner\":{\"x\":1,\"y\":2,},\"list\":[3,4,],}",
  "want": {
    "status": "success",
    "json": {"inner": {"x": 1, "y": 2}, "list": [3, 4]}
  }
}
