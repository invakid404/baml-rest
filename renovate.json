{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>invakid404/renovate-config"
  ],
  "rebaseWhen": "conflicted",
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^integration/baml_versions\\.json$/"
      ],
      "matchStrings": [
        "\"latest\":\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "@boundaryml/baml",
      "datasourceTemplate": "npm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^go\\.work$/"
      ],
      "matchStrings": [
        "(?m)^go (?<currentValue>\\S+)"
      ],
      "depNameTemplate": "go",
      "datasourceTemplate": "golang-version",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^integration/baml_versions\\.json$/"
      ],
      "matchStrings": [
        "\"source\":\\s*\"(?<currentDigest>[a-f0-9]{40})\""
      ],
      "depNameTemplate": "BoundaryML/baml",
      "datasourceTemplate": "git-refs",
      "packageNameTemplate": "https://github.com/BoundaryML/baml",
      "currentValueTemplate": "canary"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/Dockerfile\\.tmpl$/",
        "/^Dockerfile\\.builder$/",
        "/^\\.github/workflows/.*\\.yml$/"
      ],
      "matchStrings": [
        "GO_VERSION[=:]\\s*['\"]?(?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "go",
      "datasourceTemplate": "golang-version",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "description": "Update pinned CI base-image digests in Dockerfiles",
      "managerFilePatterns": [
        "/^cmd/build/Dockerfile\\.tmpl$/",
        "/^integration/mockllm/Dockerfile$/"
      ],
      "matchStrings": [
        "# renovate: datasource=docker\\s+FROM(?:\\s+--platform=[^\\s]+)?\\s+(?<depName>[^:@\\s]+):(?<currentValue>[^@\\s]+)@sha256:(?<currentDigest>[a-f0-9]{64})"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ],
  "docker": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "Batch CI base image tag/digest updates. The inherited preset disables Docker handling, so these come from the custom regex manager above (datasource=docker) rather than the native Dockerfile manager.",
      "matchManagers": [
        "custom.regex"
      ],
      "matchDatasources": [
        "docker"
      ],
      "matchFileNames": [
        "cmd/build/Dockerfile.tmpl",
        "integration/mockllm/Dockerfile"
      ],
      "matchPackageNames": [
        "rust",
        "node",
        "debian",
        "golang",
        "alpine"
      ],
      "groupName": "base docker images",
      "groupSlug": "base-docker-images"
    },
    {
      "matchDatasources": [
        "golang-version"
      ],
      "rangeStrategy": "bump",
      "groupName": "golang",
      "extractVersion": "^go(?<version>.*)$"
    },
    {
      "matchPackageNames": [
        "github.com/boundaryml/baml"
      ],
      "matchFileNames": [
        "adapters/**/go.mod"
      ],
      "enabled": false
    },
    {
      "description": "dynclient/baml-patched/go.mod is regen-managed: cmd/regenerate-dynclient copies the file verbatim from upstream BAML's go.mod (see cmd/hacks/hacks/patched_module.go writePatchedGoMod). Any Renovate bump here is reverted by the cmd/regenerate-dynclient fresh-tree gate in CI.",
      "matchFileNames": [
        "dynclient/baml-patched/go.mod"
      ],
      "enabled": false
    },
    {
      "description": "First-party module versions (github.com/invakid404/baml-rest/*) are managed by scripts/release-prep.sh as part of the release flow described in RELEASE.md, not by Renovate. Renovate's bumps for these are at best redundant (matching what release-prep + go mod tidy already do) and at worst regress root go.mod between releases. See PRs #330 and #331 for the failure mode this rule prevents.",
      "matchPackagePrefixes": [
        "github.com/invakid404/baml-rest"
      ],
      "enabled": false
    }
  ]
}
